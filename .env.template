# CONFIGURAÇÕES DA JOANA
# Copie este arquivo para ~/.joana/.env e edite com suas configurações
# NUNCA COMMITAR NO GITHUB - este é apenas um template

# ============================================================================
# LLM API (OBRIGATÓRIO - escolha apenas um)
# ============================================================================

# DeepSeek (recomendado - mais barato)
DEEPSEEK_API_KEY=""
# Modelo DeepSeek (opcional, padrão: deepseek-chat)
DEEPSEEK_MODEL="deepseek-chat"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"  # ou gpt-4-turbo, gpt-3.5-turbo

# Anthropic (Claude)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-haiku-20240307"

# Google Gemini
GOOGLE_API_KEY=""
GOOGLE_MODEL="gemini-1.5-pro"

# Provedor ativo (escolha um: deepseek, openai, anthropic, google)
LLM_PROVIDER="deepseek"

# ============================================================================
# GOOGLE APIS (OPCIONAL)
# ============================================================================

# Google Sheets CRM
GOOGLE_SHEETS_ID=""
# Pasta do Google Drive para arquivos
GOOGLE_DRIVE_FOLDER_ID=""
# Token OAuth 2.0 (gerado automaticamente)
GOOGLE_TOKEN_PATH="~/.joana/google_token.json"

# ============================================================================
# WHATSAPP (OPCIONAL)
# ============================================================================

# Evolution API ou similar
WHATSAPP_API_KEY=""
WHATSAPP_INSTANCE_ID=""
WHATSAPP_WEBHOOK_URL=""
WHATSAPP_WEBHOOK_SECRET=""

# ============================================================================
# TELEGRAM (OPCIONAL)
# ============================================================================

TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ============================================================================
# CONFIGURAÇÕES DO SISTEMA
# ============================================================================

# Diretórios
DATA_DIR="~/.joana/data"
LOG_DIR="~/.joana/logs"
CONFIG_DIR="~/.joana/config"

# Logging
LOG_LEVEL="info"  # debug, info, warning, error
LOG_FILE="joana.log"

# Fuso horário
TZ="America/Sao_Paulo"

# Idioma
LANG="pt_BR.UTF-8"

# Modo de operação
MODE="production"  # development, production, test

# ============================================================================
# BANCO DE DADOS
# ============================================================================

# SQLite (padrão)
DATABASE_PATH="~/.joana/data/joana.db"
DATABASE_BACKUP_PATH="~/.joana/data/backups"

# ============================================================================
# SEGURANÇA
# ============================================================================

# Chave de criptografia para dados sensíveis
ENCRYPTION_KEY=""

# JWT Secret para autenticação
JWT_SECRET=""

# Rate limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_FILE_SIZE_MB=10

# ============================================================================
# MEMÓRIA E APRENDIZADO
# ============================================================================

# Tamanho máximo da memória de contexto (em tokens)
MAX_CONTEXT_TOKENS=8000

# Habilitar aprendizado contínuo
ENABLE_LEARNING=true

# Diretório de memória persistente
MEMORY_DIR="~/.joana/data/memory"

# ============================================================================
# SERVIDOR WEB (OPCIONAL)
# ============================================================================

# Servidor web para interface
WEB_SERVER_ENABLED=false
WEB_SERVER_PORT=8080
WEB_SERVER_HOST="localhost"

# ============================================================================
# NOTIFICAÇÕES
# ============================================================================

# Email para notificações
EMAIL_FROM=""
EMAIL_TO=""
SMTP_SERVER=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# ============================================================================
# MONITORAMENTO
# ============================================================================

# Health checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=300  # segundos

# Métricas
METRICS_ENABLED=false
METRICS_PORT=9090

# ============================================================================
# PERSONALIZAÇÃO
# ============================================================================

# Nome do assistente
ASSISTANT_NAME="Joana"

# Personalidade (opções: professional, friendly, technical, creative)
PERSONALITY="professional"

# Idioma das respostas
RESPONSE_LANGUAGE="pt-BR"

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================

# 1. Este arquivo é um template. Copie para ~/.joana/.env e edite.
# 2. NUNCA commit este arquivo no GitHub.
# 3. Mantenha permissões seguras: chmod 600 ~/.joana/.env
# 4. Faça backup regularmente.
# 5. Rotacione chaves periodicamente.

# Para configurar automaticamente, execute:
# python3 setup_wizard.py
# ou
# bash install_joana.sh